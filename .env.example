# GitLab connection
GITLAB_API_URL=https://gitlab.example.com
GITLAB_EXTERNAL_URL=https://gitlab.example.com
# Use a dedicated bot account PAT. Leave blank in checked-in examples.
GITLAB_TOKEN=
GITLAB_WEBHOOK_SECRET=
GITLAB_SSL_VERIFY=true
GITLAB_TARGET_PROJECTS=["group/project"]
# External base URL that GitLab can call back to, used for webhook setup.
OPEN_REVIEW_EXTERNAL_URL=https://open-review.example.com

# LLM provider configuration
# `LLM_MODEL_ID` remains as a compatibility field and is auto-synced from the active provider + model.
LLM_ACTIVE_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
LLM_MODEL_ID=

# Sandbox
SANDBOX_TYPE=local
# DOCKER_IMAGE=open-review/sandbox:0.1.0  # for docker sandbox
# Local sandbox/cache/runtime state is fixed under /var/lib/open-review

# Durable runtime
WORKER_CONCURRENCY=10
MR_ACTOR_LEASE_SECONDS=900
RUN_HEARTBEAT_SECONDS=30
MENTION_BATCH_WINDOW_SECONDS=15
OPEN_REVIEW_DOCKER_NETWORK=open-review-net
OPEN_REVIEW_IMAGE=open-review:0.1.0
OPEN_REVIEW_WORKER_CONTAINER_NAME=open-review-worker
OPEN_REVIEW_PHOENIX_CONTAINER_NAME=open-review-phoenix
OPEN_REVIEW_PHOENIX_DB_CONTAINER_NAME=open-review-phoenix-db
OPEN_REVIEW_PHOENIX_IMAGE=open-review/phoenix:14.2.1
OPEN_REVIEW_SANDBOX_IMAGE=open-review/sandbox:0.1.0
OPEN_REVIEW_POSTGRES_IMAGE=postgres:16-alpine

# Control plane / admin console
# SQLite state is fixed at /var/lib/open-review/controlplane.db
ADMIN_INITIAL_PASSWORD=
ADMIN_SESSION_SECRET=

# Optional local Phoenix tracing
PHOENIX_TRACING_ENABLED=false
PHOENIX_COLLECTOR_ENDPOINT=
PHOENIX_API_KEY=
PHOENIX_PROJECT_NAME=open-review
PHOENIX_UI_BASE_URL=
