OPEN_REVIEW_PHOENIX_IMAGE=open-review/phoenix:14.2.1
OPEN_REVIEW_POSTGRES_IMAGE=postgres:16-alpine

PHOENIX_PORT=6006
PHOENIX_OTLP_GRPC_PORT=4317

POSTGRES_DB=phoenix
POSTGRES_USER=phoenix
POSTGRES_PASSWORD=change-me

PHOENIX_ENABLE_AUTH=true
PHOENIX_SECRET=change-me-32chars-min1digit1lower
PHOENIX_DEFAULT_ADMIN_INITIAL_PASSWORD=change-me-admin

# The bot should use a Phoenix system API key created from the Phoenix UI after first login.
