OPEN_REVIEW_IMAGE=open-review:0.1.0
OPEN_REVIEW_SANDBOX_IMAGE=open-review/sandbox:0.1.0
OPEN_REVIEW_PHOENIX_IMAGE=arizephoenix/phoenix:14.2.1
OPEN_REVIEW_POSTGRES_IMAGE=postgres:16-alpine

OPEN_REVIEW_WEB_PORT=8000
PHOENIX_PORT=6006
PHOENIX_OTLP_GRPC_PORT=4317
OPEN_REVIEW_UID=
OPEN_REVIEW_GID=
OPEN_REVIEW_DOCKER_GID=

POSTGRES_DB=phoenix
POSTGRES_USER=phoenix
POSTGRES_PASSWORD=change-me
PHOENIX_ENABLE_AUTH=false
PHOENIX_SECRET=change-me-32chars-min1digit1lower
PHOENIX_DEFAULT_ADMIN_INITIAL_PASSWORD=change-me-admin

PHOENIX_TRACING_ENABLED=true
PHOENIX_API_KEY=local-dev-phoenix-key
PHOENIX_PROJECT_NAME=open-review
PHOENIX_UI_BASE_URL=http://localhost:6006
